<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maxime Bodivit Vision Ext - Adobe Premiere Pro extension
  Tabs:
    1. B-Roll : extract portions from clips on a source track and place
       full-handle copies on a destination track.
    2. Compactage : remove all gaps between clips on a chosen track.
-->
<ExtensionManifest Version="6.0"
                   ExtensionBundleId="com.maximebodivit.visionext"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="Maxime Bodivit Vision Ext"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.maximebodivit.visionext.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 2025 = version 25.x, Premiere Pro 2026 = version 26.x -->
      <Host Name="PPRO" Version="[25.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.maximebodivit.visionext.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Maxime Bodivit Vision Ext</Menu>
          <Geometry>
            <Size>
              <Height>620</Height>
              <Width>360</Width>
            </Size>
            <MinSize>
              <Height>520</Height>
              <Width>320</Width>
            </MinSize>
            <MaxSize>
              <Height>2000</Height>
              <Width>900</Width>
            </MaxSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
